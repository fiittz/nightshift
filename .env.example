# ═══════════════════════════════════════════════
# NIGHTSHIFT — Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# LLM Provider (any OpenAI-compatible API)
LLM_BASE_URL=https://api.tensorix.ai/v1
LLM_API_KEY=your-api-key

# Or use Anthropic directly
# ANTHROPIC_API_KEY=your-key

# Product repo (the codebase agents work on)
PRODUCT_REPO_URL=https://github.com/you/your-product.git
PRODUCT_REPO_SLUG=you/your-product

# Telegram (optional — for mobile interface)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Agent workspace root
AGENT_HOME=/home/ubuntu/agents
