{
  "company": {
    "id": "my-company",
    "name": "My AI Company",
    "founder": "Your Name",
    "settings": {
      "requireApprovalForNewHires": true,
      "maxAgents": 20,
      "defaultModel": "deepseek/deepseek-v3.2",
      "stabilityFirst": true
    },
    "repos": [
      {
        "id": "my-product",
        "url": "${PRODUCT_REPO_URL}",
        "branch": "main",
        "path": "product-repo",
        "type": "product",
        "description": "Main product repository"
      }
    ],
    "branchStrategy": {
      "engineerPrefix": true,
      "protectedBranches": ["main"],
      "namingConvention": "<agent>/<task-slug>"
    },
    "telegram": {
      "botTokenEnvVar": "TELEGRAM_BOT_TOKEN",
      "chatIdEnvVar": "TELEGRAM_CHAT_ID"
    },
    "llm": {
      "provider": "openai-compatible",
      "baseUrl": "${LLM_BASE_URL}",
      "apiKeyEnvVar": "LLM_API_KEY"
    }
  },
  "agents": [
    {
      "id": "ceo",
      "name": "CEO",
      "role": "Chief Executive Officer",
      "title": "Strategy, agenda, quality audits, hiring",
      "status": "idle",
      "reportsTo": null,
      "permissions": { "canCreateAgents": true, "canFireAgents": true, "canSetAgenda": true },
      "adapterConfig": { "model": "deepseek/deepseek-v3.2", "promptFile": "agents/ceo.md" },
      "runtimeConfig": { "heartbeat": { "intervalRounds": 5 } },
      "budget": { "monthlyCentsLimit": 5000, "spentCents": 0, "totalTokens": 0 },
      "stats": { "totalRuns": 0 }
    },
    {
      "id": "pm",
      "name": "PM",
      "role": "Product Manager",
      "title": "Specs, backlog, task breakdowns",
      "status": "idle",
      "reportsTo": "ceo",
      "permissions": { "canWriteBacklog": true },
      "adapterConfig": { "model": "deepseek/deepseek-v3.2", "promptFile": "agents/pm.md" },
      "budget": { "monthlyCentsLimit": 3000, "spentCents": 0, "totalTokens": 0 },
      "stats": { "totalRuns": 0 }
    },
    {
      "id": "backend",
      "name": "Backend Engineer",
      "role": "Backend Engineer",
      "title": "APIs, business logic, data layer",
      "status": "idle",
      "reportsTo": "coo",
      "permissions": { "canWriteCode": true, "canPushBranches": true },
      "adapterConfig": { "model": "deepseek/deepseek-v3.2", "promptFile": "agents/backend.md" },
      "budget": { "monthlyCentsLimit": 5000, "spentCents": 0, "totalTokens": 0 },
      "stats": { "totalRuns": 0 }
    },
    {
      "id": "frontend",
