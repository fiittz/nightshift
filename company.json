      "adapterConfig": { "model": "deepseek/deepseek-v3.2", "promptFile": "agents/frontend.md" },
      "budget": { "monthlyCentsLimit": 5000, "spentCents": 0, "totalTokens": 0 },
      "stats": { "totalRuns": 0 }
    },
    {
      "id": "qa",
      "name": "QA",
      "role": "QA Engineer",
      "title": "Code review, tests, impact analysis",
